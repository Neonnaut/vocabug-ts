{
  "name": "vocabug",
  "version": "0.1.0",
  "type": "module",


  "description": "Word generator program for conlangers",
  "author": "Neonnaut",
  "license": "MIT",
  "homepage": "https://neonnaut.neocities.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neonnaut/vocabug-ts.git"
  },
  "bugs": {
    "url": "https://github.com/Neonnaut/vocabug-ts/issues"
  },
